# ContractIQ — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase — Settings > API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=              # Project URL, e.g. https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # anon/public key — safe to expose to the browser
SUPABASE_SERVICE_ROLE_KEY=             # SERVER ONLY — full-access key, used only in Route Handlers; never import in client components

# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=                        # SERVER ONLY — used only in Route Handlers for extraction and chat; never expose to the client
